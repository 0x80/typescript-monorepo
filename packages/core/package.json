{
  "name": "@repo/core",
  "version": "0.0.0",
  "description": "Code to share between backend apps/services",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    "./db-refs": "./dist/db-refs.mjs",
    "./firebase": "./dist/firebase.mjs",
    "./utils": "./dist/utils/index.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "check-types": "tsc --noEmit",
    "check-circular": "madge --circular --extensions ts ./src --ts-config ./tsconfig.json",
